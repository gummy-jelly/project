# 이 파일을 terraform.tfvars로 복사하고 값 채우기
# cp terraform.tfvars.example terraform.tfvars

aws_region  = "ap-northeast-2"
project     = "cloudprep"
db_name     = "cloudprep"
db_username = "admin"
db_password = "your_secure_password_here"  # 변경 필수!
my_ip       = "x.x.x.x/32"               # 내 IP로 변경 (curl ifconfig.me)
